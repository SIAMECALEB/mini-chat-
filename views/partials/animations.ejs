<style>
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(20px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .fade-up {
    animation: fadeUp 0.6s ease-out forwards;
  }

  .delay-1 { animation-delay: 0.1s }
  .delay-2 { animation-delay: 0.2s }
  .delay-3 { animation-delay: 0.3s }
</style>
