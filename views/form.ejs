<!DOCTYPE html>
<html>
<head>
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest"></script>
</head>

<body class="min-h-screen bg-gradient-to-br from-indigo-600 via-purple-600 to-pink-600
             flex items-center justify-center p-6">

  <form method="POST" action="/new"
    class="bg-white/20 backdrop-blur border border-white/30
           rounded-2xl p-8 w-full max-w-md shadow-2xl fade-up space-y-5">

    <h2 class="text-3xl font-bold text-white flex gap-2">
      <i data-lucide="message-square"></i> New Message
    </h2>

    <input name="messageUser" placeholder="Your name" required
      class="w-full p-3 rounded-xl focus:ring-2 focus:ring-purple-500" />

    <textarea name="messageText" rows="4" placeholder="Your message" required
      class="w-full p-3 rounded-xl focus:ring-2 focus:ring-purple-500"></textarea>

    <button
      class="w-full bg-gradient-to-r from-indigo-600 to-purple-600
             text-white font-semibold py-3 rounded-xl
             hover:scale-[1.03] active:scale-95 transition">
      Send 🚀
    </button>

    <a href="/" class="text-white/80 text-center block">← Back</a>
  </form>

  <script>lucide.createIcons()</script>
</body>
</html>
